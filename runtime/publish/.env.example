# Bitiful credentials for voice-asr release upload (publish/Upload-VoiceAsrToBitiful.ps1).
# Copy to publish/.env — gitignored. Monorepo maintainers may reuse quicker-rpc/publish/.env instead.
# GitHub Actions release workflow uploads to Bitiful automatically (repo Secrets + optional Variables below).

BITIFUL_ACCESS_KEY=
BITIFUL_SECRET_KEY=
BITIFUL_BUCKET_NAME=quicker-pkgs
BITIFUL_ENDPOINT_URL=https://s3.bitiful.net
BITIFUL_VOICE_ASR_OBJECT_PREFIX=quicker-rpc/voice-asr
