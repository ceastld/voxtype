{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxType",
  "version": "0.1.11",
  "identifier": "app.voxtype.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:2430",
    "beforeBuildCommand": "pwsh -NoProfile -ExecutionPolicy Bypass -File ../scripts/prepare-tauri-build.ps1 && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxType 设置",
        "width": 760,
        "height": 520,
        "minWidth": 640,
        "minHeight": 420,
        "maxHeight": 880,
        "center": true,
        "resizable": true,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "VoxType",
        "url": "overlay.html",
        "width": 520,
        "height": 140,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "focus": false,
        "focusable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundle-resources/runtime/voxtype-runtime/": "runtime/voxtype-runtime/",
      "bundle-resources/catalog/models.json": "catalog/models.json"
    }
  }
}
