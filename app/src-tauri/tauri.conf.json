{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxType",
  "version": "0.1.0",
  "identifier": "app.voxtype.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxType 设置",
        "width": 760,
        "height": 640,
        "center": true,
        "resizable": true,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "VoxType",
        "url": "overlay.html",
        "width": 200,
        "height": 48,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "resizable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../catalog/models.json": "catalog/models.json"
    }
  }
}
